[Unit]
Description=Reloop Celery Worker
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/reloop-backend/reloopsms-backend
ExecStart=/home/ubuntu/reloop-backend/venv/bin/celery -A reloopsms worker -l info -Q critical,celery
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
