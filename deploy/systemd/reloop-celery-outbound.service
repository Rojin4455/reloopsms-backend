[Unit]
Description=Reloop Celery Outbound SMS Worker
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/reloop-backend/reloopsms-backend
ExecStart=/home/ubuntu/reloop-backend/venv/bin/celery -A reloopsms worker -l info -Q outbound --concurrency=2 --prefetch-multiplier=1 -n outbound@%h
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
